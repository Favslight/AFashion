    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "file-type": "^22.0.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "resend": "^4.1.2",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.0.0",
