{
  "name": "what-should-i-wear-backend",
  "version": "1.0.0",
  "description": "Production-ready Fastify backend for the What Should I Wear? AI fashion styling platform.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
